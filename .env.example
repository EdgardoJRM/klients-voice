# Copy to packages/api/.env (local Invoke) or set in Lambda / CI

AWS_REGION=us-east-1

# DynamoDB tables (logical names → physical from SAM outputs)
TABLE_TENANTS=
TABLE_USERS=
TABLE_EVENTS=
TABLE_PARTICIPANTS=
TABLE_CALL_LOGS=
TABLE_INTEGRATIONS=
TABLE_PHONE_NUMBERS=
TABLE_AGENTS=

# Email logs (SES transactional)
TABLE_EMAIL_LOGS=

# Private S3 bucket (QR, future labels/materials) — name from SAM AssetsBucketName output
S3_BUCKET_ASSETS=

# Verified SES sender (From)
SES_FROM_EMAIL=

# Secrets Manager ARNs (production)
SECRET_ELEVENLABS_ARN=
SECRET_TWILIO_ARN=

# Local dev overrides (omit in Lambda)
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Webhooks
CLICKFUNNELS_WEBHOOK_SECRET=
ELEVENLABS_WEBHOOK_SECRET=

COGNITO_JWKS_URL=
COGNITO_ISSUER=
COGNITO_AUDIENCE=

# Dashboard — packages/dashboard/.env.local
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_KV_TENANT_ID=

